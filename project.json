{
  "projectName": "Annamacharya University Portal",
  "type": "Full Stack Web Application",
  "frontend": {
    "entry": "index.html",
    "styles": "styles.css",
    "logic": "app.js",
    "theme": "Professional academic portal"
  },
  "backend": {
    "entry": "server.py",
    "framework": "Python HTTP server",
